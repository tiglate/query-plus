@page "{id:int}"
@model QueryPlus.Web.Pages.Admin.Categories.ViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L
@{
    ViewData["Title"] = L["Categories_View"].Value;
}

<div class="qp-page space-y-4">
    <div class="qp-card max-w-3xl">
        <div class="qp-card-header">
            <h1 class="text-xl font-semibold">@L["Categories_View"]</h1>
            <div class="flex gap-2">
                <a asp-page="Edit" asp-route-id="@Model.Item.Id" class="qp-btn-primary">@L["Edit"]</a>
                <a asp-page="Index" class="qp-btn-secondary">@L["Back"]</a>
            </div>
        </div>
        <div class="qp-card-body space-y-3 text-sm">
            <div><span class="text-slate-500">@L["Id"]</span><div class="font-medium">@Model.Item.Id</div></div>
            <div><span class="text-slate-500">@L["Description"]</span><div class="font-medium">@Model.Item.Description</div></div>
        </div>
    </div>
    <div class="qp-card max-w-3xl">
        <div class="qp-card-header"><h2 class="font-semibold">@L["Audit"]</h2></div>
        <div class="qp-card-body grid grid-cols-2 gap-4 text-sm">
            <div><span class="text-slate-500">@L["CreatedAt"]</span><div>@Model.Item.CreatedAt.ToLocalTime().ToString("g")</div></div>
            <div><span class="text-slate-500">@L["UpdatedAt"]</span><div>@(Model.Item.UpdatedAt?.ToLocalTime().ToString("g") ?? "—")</div></div>
        </div>
    </div>
</div>
