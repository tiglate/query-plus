@page "{id:int}"
@model QueryPlus.Web.Pages.Admin.Categories.EditModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L
@{
    ViewData["Title"] = L["Categories_Edit"].Value;
}

<div class="qp-page space-y-4">
    <div class="qp-card">
        <div class="qp-card-header">
            <h1 class="qp-page-title">
                <i class="fa-solid fa-pen-to-square text-cyan" aria-hidden="true"></i>
                @L["Categories_Edit"]
            </h1>
            <div class="flex flex-wrap items-center justify-end gap-1.5">
                <button type="submit" form="category-form" class="qp-btn-primary">
                    <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                    @L["Save"]
                </button>
                <a asp-page="View" asp-route-id="@Model.Input.Id" class="qp-btn-secondary">
                    <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                    @L["Cancel"]
                </a>
                <a asp-page="Index" class="qp-btn-secondary">
                    <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
                    @L["Back"]
                </a>
            </div>
        </div>
    </div>

    <div class="qp-card">
        <div class="qp-card-header">
            <h2 class="qp-section-title">
                <i class="fa-solid fa-folder" aria-hidden="true"></i>
                @L["Categories_Title"]
            </h2>
        </div>
        <div class="qp-card-body">
            <form id="category-form" method="post">
                <input type="hidden" asp-for="Input.Id" />
                <div class="flex flex-wrap items-start gap-4">
                    <div class="w-28 shrink-0">
                        <label class="qp-label">@L["Id"]</label>
                        <input class="qp-input bg-slate-50" value="@Model.Input.Id" readonly />
                    </div>
                    <div class="qp-category-description min-w-0">
                        <label class="qp-label" asp-for="Input.Description">@L["Description"]</label>
                        <input class="qp-input" asp-for="Input.Description" />
                        <span asp-validation-for="Input.Description" class="text-sm text-red-600"></span>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="qp-card">
        <div class="qp-card-header">
            <h2 class="qp-section-title">
                <i class="fa-solid fa-clock-rotate-left" aria-hidden="true"></i>
                @L["Audit"]
            </h2>
        </div>
        <div class="qp-card-body">
            <div class="grid max-w-3xl grid-cols-2 gap-4 text-sm">
                <div><span class="text-slate-500">@L["CreatedAt"]</span><div>@Model.CreatedAt.ToLocalTime().ToString("g")</div></div>
                <div><span class="text-slate-500">@L["UpdatedAt"]</span><div>@(Model.UpdatedAt?.ToLocalTime().ToString("g") ?? "—")</div></div>
            </div>
        </div>
    </div>
</div>
