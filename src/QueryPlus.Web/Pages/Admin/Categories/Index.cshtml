@page
@model QueryPlus.Web.Pages.Admin.Categories.IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@using System.Net
@{
    ViewData["Title"] = L["Categories_Title"].Value;

    const int idToken = 987654321;
    var viewUrlTemplate = (Url.Page("View", new { id = idToken }) ?? "").Replace(idToken.ToString(), "__ID__");
    var editUrlTemplate = (Url.Page("Edit", new { id = idToken }) ?? "").Replace(idToken.ToString(), "__ID__");
    var deleteBase = Url.Page("./Index", "Delete") ?? "./Index?handler=Delete";
    var antiforgery = Antiforgery.GetAndStoreTokens(HttpContext).RequestToken ?? "";

    string ActionsHtml(int id)
    {
        var viewUrl = viewUrlTemplate.Replace("__ID__", id.ToString());
        var editUrl = editUrlTemplate.Replace("__ID__", id.ToString());
        var deleteUrl = deleteBase + (deleteBase.Contains('?', StringComparison.Ordinal) ? "&" : "?")
                        + "id=" + id;
        var desc = WebUtility.HtmlEncode(Model.Description ?? "");
        return
            $"""
             <div class="qp-grid-actions">
               <a class="qp-btn-ghost" href="{WebUtility.HtmlEncode(viewUrl)}"><i class="fa-solid fa-eye" aria-hidden="true"></i> {WebUtility.HtmlEncode(L["View"].Value)}</a>
               <a class="qp-btn-ghost" href="{WebUtility.HtmlEncode(editUrl)}"><i class="fa-solid fa-pen" aria-hidden="true"></i> {WebUtility.HtmlEncode(L["Edit"].Value)}</a>
               <form method="post" action="{WebUtility.HtmlEncode(deleteUrl)}" class="inline" data-confirm="{WebUtility.HtmlEncode(L["ConfirmDelete"].Value)}">
                 <input type="hidden" name="__RequestVerificationToken" value="{WebUtility.HtmlEncode(antiforgery)}" />
                 <input type="hidden" name="Description" value="{desc}" />
                 <input type="hidden" name="PageNumber" value="{Model.PageNumber}" />
                 <input type="hidden" name="PageSize" value="{Model.PageSize}" />
                 <button type="submit" class="qp-btn-ghost text-red-700"><i class="fa-solid fa-trash" aria-hidden="true"></i> {WebUtility.HtmlEncode(L["Delete"].Value)}</button>
               </form>
             </div>
             """;
    }

    var cells = Model.Items.Select(item => (IReadOnlyList<string>)new[]
    {
        item.Id.ToString(),
        item.Description,
        item.CreatedAt.ToLocalTime().ToString("g"),
        item.UpdatedAt?.ToLocalTime().ToString("g") ?? "—",
        ActionsHtml(item.Id)
    }).ToList();

    var sheet = new SheetGridModel
    {
        Columns =
        [
            new SheetGridColumn { Caption = L["Id"].Value, Align = "right", Width = 70 },
            new SheetGridColumn { Caption = L["Description"].Value },
            new SheetGridColumn { Caption = L["CreatedAt"].Value },
            new SheetGridColumn { Caption = L["UpdatedAt"].Value },
            new SheetGridColumn { Caption = L["Actions"].Value, IsHtml = true, Sortable = false, Width = 220 }
        ],
        Cells = cells,
        EmptyMessage = L["NoRecords"].Value,
        MetaText = string.Format(L["Pagination_Summary"].Value,
            Model.Pager.FromItem, Model.Pager.ToItem, Model.Pager.TotalCount),
        ShowInteractionHint = true,
        CssClass = "qp-sheet-grid--admin"
    };
}

<div class="qp-page qp-admin-search-page">
    @* Toolbar: title left, actions right *@
    <div class="qp-card shrink-0">
        <div class="qp-card-header">
            <h1 class="qp-page-title">
                <i class="fa-solid fa-folder text-cyan" aria-hidden="true"></i>
                @L["Categories_Title"]
            </h1>
            <div class="flex flex-wrap items-center justify-end gap-1.5">
                <button type="submit" form="categories-filter-form" class="qp-btn-primary">
                    <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                    @L["Search"]
                </button>
                <a asp-page="./Index" class="qp-btn-secondary">
                    <i class="fa-solid fa-eraser" aria-hidden="true"></i>
                    @L["Clear"]
                </a>
                <a asp-page="Create" class="qp-btn-accent">
                    <i class="fa-solid fa-plus" aria-hidden="true"></i>
                    @L["Create"]
                </a>
            </div>
        </div>
    </div>

    @* Filters *@
    <div class="qp-card shrink-0">
        <div class="qp-card-header">
            <h2 class="qp-section-title">
                <i class="fa-solid fa-filter" aria-hidden="true"></i>
                @L["Filter"]
            </h2>
        </div>
        <div class="qp-card-body">
            <form id="categories-filter-form" method="get" class="grid grid-cols-1 gap-2 md:grid-cols-3">
                <div class="md:col-span-2">
                    <label class="qp-label" asp-for="Description">@L["Description"]</label>
                    <input class="qp-input" asp-for="Description" />
                </div>
                <div>
                    <label class="qp-label" asp-for="PageSize">@L["Pagination_PageSize"]</label>
                    <select class="qp-input" asp-for="PageSize">
                        <option value="10">10</option>
                        <option value="20">20</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>
            </form>
        </div>
    </div>

    @* Results — fills remaining viewport height *@
    <div class="qp-card qp-admin-results-card">
        <div class="qp-card-header shrink-0">
            <h2 class="qp-section-title">
                <i class="fa-solid fa-table" aria-hidden="true"></i>
                @L["Home_Results"]
            </h2>
        </div>
        <div class="qp-card-body qp-admin-results-body">
            <partial name="Shared/Partials/_SheetGrid" model="sheet" />
            <div class="qp-admin-results-pager shrink-0">
                <partial name="Partials/_Pager" model="Model.Pager" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.js-sheet-root.qp-sheet-grid--admin').forEach(function (el) {
                if (window.QueryPlusSheetGrid) QueryPlusSheetGrid.mount(el);
            });
        });
    </script>
}
