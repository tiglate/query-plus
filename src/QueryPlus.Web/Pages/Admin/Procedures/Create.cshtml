@page
@model QueryPlus.Web.Pages.Admin.Procedures.CreateModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L
@{
    ViewData["Title"] = L["Procedures_New"].Value;
    ViewData["CategoryOptions"] = Model.CategoryOptions;
    // Ensure form field names / ModelState keys are "Input.Property" so binding and validation match.
    ViewData.TemplateInfo.HtmlFieldPrefix = "Input";
}

<div class="qp-page">
    <div class="qp-card">
        <div class="qp-card-header">
            <h1 class="qp-page-title">@L["Procedures_New"]</h1>
            <a asp-page="Index" class="qp-btn-secondary"><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> @L["Back"]</a>
        </div>
        <div class="qp-card-body">
            <form method="post" novalidate>
                <partial name="~/Pages/Shared/Partials/_ProcedureEditForm.cshtml" model="Model.Input" view-data="ViewData" />
                <div class="mt-6 flex gap-2">
                    <button type="submit" asp-page-handler="Save" class="qp-btn-primary"><i class="fa-solid fa-floppy-disk" aria-hidden="true"></i> @L["Save"]</button>
                    <a asp-page="Index" class="qp-btn-secondary"><i class="fa-solid fa-xmark" aria-hidden="true"></i> @L["Cancel"]</a>
                </div>
            </form>
        </div>
    </div>
</div>
