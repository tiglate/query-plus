@page
@model QueryPlus.Web.Pages.Admin.Procedures.CreateModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L
@{
    ViewData["Title"] = L["Procedures_New"].Value;
    ViewData["PageKey"] = "admin-procedure-edit";
    ViewData["CategoryOptions"] = Model.CategoryOptions;
    // Ensure form field names / ModelState keys are "Input.Property" so binding and validation match.
    ViewData.TemplateInfo.HtmlFieldPrefix = "Input";
}

<div class="qp-page space-y-4">
    <div class="qp-card">
        <div class="qp-card-header">
            <h1 class="qp-page-title">
                <i class="fa-solid fa-file-circle-plus text-cyan" aria-hidden="true"></i>
                @L["Procedures_New"]
            </h1>
            <div class="flex flex-wrap items-center justify-end gap-1.5">
                <button type="submit" form="procedure-form" formaction="?handler=Save" class="qp-btn-primary">
                    <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                    @L["Save"]
                </button>
                <a asp-page="Index" class="qp-btn-secondary">
                    <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                    @L["Cancel"]
                </a>
                <a asp-page="Index" class="qp-btn-secondary">
                    <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
                    @L["Back"]
                </a>
            </div>
        </div>
    </div>

    <form id="procedure-form" method="post" novalidate class="space-y-4">
        <partial name="~/Pages/Shared/Partials/_ProcedureEditForm.cshtml" model="Model.Input" view-data="ViewData" />
    </form>
</div>
