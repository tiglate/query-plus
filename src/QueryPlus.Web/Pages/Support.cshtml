@page
@model QueryPlus.Web.Pages.SupportModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L
@{
    ViewData["Title"] = L["Support_Title"].Value;
}

<div class="qp-page space-y-4">
    @* Toolbar: title left, actions right (same pattern as admin/detail pages). *@
    <div class="qp-card">
        <div class="qp-card-header">
            <h1 class="qp-page-title">
                <i class="fa-solid fa-life-ring text-cyan" aria-hidden="true"></i>
                @L["Support_Title"]
            </h1>
            <div class="flex flex-wrap items-center justify-end gap-1.5">
                <a class="qp-btn-primary"
                   href="https://www.google.com"
                   target="_blank"
                   rel="noopener noreferrer"
                   title="@L["Support_Mantis"]">
                    <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
                    @L["Support_Mantis"]
                </a>
            </div>
        </div>
    </div>

    <div class="qp-card">
        <div class="qp-card-body">
            <div class="grid items-stretch gap-6 lg:grid-cols-5 lg:gap-8">
                @* Contact details — majority of width *@
                <div class="flex min-w-0 flex-col gap-4 lg:col-span-3">
                    <p class="text-sm text-slate-600 dark:text-slate-300">@L["Support_Body"]</p>
                    <dl class="grid flex-1 grid-cols-1 gap-3 sm:grid-cols-2">
                        <div class="flex flex-col rounded-md border border-slate-200 bg-slate-50/60 p-4 dark:border-navy-600 dark:bg-navy-900/50">
                            <dt class="inline-flex items-center gap-1.5 text-xs font-semibold text-navy dark:text-slate-100">
                                <i class="fa-solid fa-headset text-cyan" aria-hidden="true"></i>
                                @L["Support_Helpdesk"]
                            </dt>
                            <dd class="mt-2 text-sm">
                                <a class="text-cyan-700 underline dark:text-cyan"
                                   href="https://helpdesk.example.com"
                                   target="_blank"
                                   rel="noopener noreferrer">helpdesk.example.com</a>
                            </dd>
                        </div>
                        <div class="flex flex-col rounded-md border border-slate-200 bg-slate-50/60 p-4 dark:border-navy-600 dark:bg-navy-900/50">
                            <dt class="inline-flex items-center gap-1.5 text-xs font-semibold text-navy dark:text-slate-100">
                                <i class="fa-solid fa-phone text-cyan" aria-hidden="true"></i>
                                @L["Support_Phone"]
                            </dt>
                            <dd class="mt-2 text-sm">+55 (11) 0000-0000</dd>
                        </div>
                        <div class="flex flex-col rounded-md border border-slate-200 bg-slate-50/60 p-4 dark:border-navy-600 dark:bg-navy-900/50">
                            <dt class="inline-flex items-center gap-1.5 text-xs font-semibold text-navy dark:text-slate-100">
                                <i class="fa-solid fa-envelope text-cyan" aria-hidden="true"></i>
                                @L["Support_Email"]
                            </dt>
                            <dd class="mt-2 text-sm">
                                <a class="text-cyan-700 underline dark:text-cyan"
                                   href="mailto:support@queryplus.local">support@queryplus.local</a>
                            </dd>
                        </div>
                        <div class="flex flex-col rounded-md border border-slate-200 bg-slate-50/60 p-4 dark:border-navy-600 dark:bg-navy-900/50">
                            <dt class="inline-flex items-center gap-1.5 text-xs font-semibold text-navy dark:text-slate-100">
                                <i class="fa-solid fa-clock text-cyan" aria-hidden="true"></i>
                                @L["Support_Hours"]
                            </dt>
                            <dd class="mt-2 text-sm">Seg–Sex · 09:00–18:00 (BRT)</dd>
                        </div>
                    </dl>
                </div>

                @* Decorative illustration (bundled SVG, QueryPlus palette — free with the app). *@
                <div class="flex min-h-[14rem] items-center justify-center lg:col-span-2 lg:min-h-0">
                    <img src="~/images/support-illustration.svg"
                         asp-append-version="true"
                         alt=""
                         class="h-auto w-full max-w-md object-contain dark:opacity-90 lg:max-w-none"
                         width="640"
                         height="480"
                         decoding="async" />
                </div>
            </div>
        </div>
    </div>
</div>
