@page
@model ErrorModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L
@{
    var is404 = Model.IsNotFound;
    ViewData["Title"] = is404
        ? L["Error_NotFound_Title"].Value
        : string.Format(L["Error_Server_Title"].Value, Model.StatusCodeValue);

    var title = is404 ? L["Error_NotFound_Title"].Value : string.Format(L["Error_Server_Title"].Value, Model.StatusCodeValue);
    var lead = is404 ? L["Error_NotFound_Lead"].Value : L["Error_Server_Lead"].Value;
    var body = is404 ? L["Error_NotFound_Body"].Value : L["Error_Server_Body"].Value;
    var codeBadge = Model.StatusCodeValue.ToString();
}

<div class="qp-page">
    <div class="qp-card overflow-hidden">
        <div class="qp-card-body">
            <div class="grid items-center gap-8 lg:grid-cols-2 lg:gap-10">
                <div class="order-2 flex flex-col gap-4 lg:order-1">
                    <div class="inline-flex w-fit items-center gap-2 rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-wide text-slate-600 dark:border-navy-600 dark:bg-navy-900 dark:text-slate-300">
                        <span class="inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-navy px-1.5 font-mono text-[10px] text-white dark:bg-cyan dark:text-navy">
                            @codeBadge
                        </span>
                        HTTP
                    </div>

                    <h1 class="text-2xl font-bold tracking-tight text-navy dark:text-slate-50 sm:text-3xl">
                        @title
                    </h1>
                    <p class="text-base font-medium text-cyan-700 dark:text-cyan">
                        @lead
                    </p>
                    <p class="max-w-xl text-sm leading-relaxed text-slate-600 dark:text-slate-300">
                        @body
                    </p>

                    @if (Model.ShowRequestId)
                    {
                        <p class="text-[11px] text-slate-500 dark:text-slate-400">
                            <span class="font-medium">@L["Error_RequestId"]:</span>
                            <code class="ml-1 rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[10px] dark:bg-navy-900">@Model.RequestId</code>
                        </p>
                    }

                    <div class="mt-2 flex flex-wrap gap-2">
                        <a asp-page="/Index" class="qp-btn-primary">
                            <i class="fa-solid fa-house" aria-hidden="true"></i>
                            @L["Error_GoHome"]
                        </a>
                        <a asp-page="/Support" class="qp-btn-secondary">
                            <i class="fa-solid fa-life-ring" aria-hidden="true"></i>
                            @L["Error_ContactSupport"]
                        </a>
                        @if (is404)
                        {
                            <button type="button" class="qp-btn-ghost" onclick="history.length > 1 ? history.back() : (location.href='@Url.Page("/Index")')">
                                <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
                                @L["Back"]
                            </button>
                        }
                    </div>
                </div>

                <div class="order-1 flex items-center justify-center lg:order-2">
                    @if (is404)
                    {
                        <img src="~/images/error-404.svg"
                             asp-append-version="true"
                             alt=""
                             class="h-auto w-full max-w-md object-contain dark:opacity-95 lg:max-w-none"
                             width="640"
                             height="420"
                             decoding="async" />
                    }
                    else
                    {
                        <img src="~/images/error-500.svg"
                             asp-append-version="true"
                             alt=""
                             class="h-auto w-full max-w-md object-contain dark:opacity-95 lg:max-w-none"
                             width="640"
                             height="420"
                             decoding="async" />
                    }
                </div>
            </div>
        </div>
    </div>
</div>
