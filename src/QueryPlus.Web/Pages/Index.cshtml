@page
@model IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L
@{
    ViewData["Title"] = L["Home_Title"].Value;
    var hasProcedure = Model.ProcedureId is > 0;
}

<div class="qp-page space-y-4"
     data-msg-select-procedure="@L["Home_SelectProcedureRequired"]"
     data-msg-export-requires-data="@L["Home_ExportRequiresData"]"
     data-msg-required-params="@L["Home_RequiredParametersClient"]"
     data-msg-required-params-multi="@L["Home_RequiredParametersMissing"]">
    <div class="qp-card">
        <div class="qp-card-header">
            <h1 class="text-xl font-semibold text-navy">@L["Home_Title"]</h1>
            <div class="flex flex-wrap gap-2">
                <button type="button"
                        id="btn-execute"
                        class="qp-btn-primary"
                        hx-post="?handler=Execute"
                        hx-include="#exec-form"
                        hx-target="#results-panel"
                        hx-swap="innerHTML"
                        hx-indicator="#exec-indicator"
                        disabled="@(!hasProcedure)"
                        title="@L["Home_SelectProcedureRequired"]">
                    @L["Home_Execute"]
                </button>
                <button type="button"
                        id="btn-clear"
                        class="qp-btn-secondary"
                        data-clear-url="@Url.Page("/Index")"
                        disabled="@(!hasProcedure)"
                        title="@L["Home_SelectProcedureRequired"]">
                    @L["Clear"]
                </button>
                <button type="button"
                        id="btn-export"
                        class="qp-btn-accent"
                        hx-post="?handler=Export"
                        hx-include="#exec-form"
                        hx-target="#export-status"
                        hx-swap="innerHTML"
                        disabled="disabled"
                        title="@L["Home_ExportRequiresData"]">
                    @L["Home_Export"]
                </button>
                <span id="exec-indicator" class="htmx-indicator text-sm text-slate-500">…</span>
            </div>
        </div>
        <div class="qp-card-body space-y-4">
            @* Enter is intercepted in site.js (prevent full post that wipes procedure list). *@
            <form id="exec-form" method="post" class="js-exec-form">
                @Html.AntiForgeryToken()
                <div class="grid grid-cols-1 gap-4 lg:grid-cols-3">
                    <div>
                        <label class="qp-label" for="procedureId">@L["Home_SelectProcedure"]</label>
                        <select id="procedureId" class="qp-input js-procedure-select"
                                asp-for="ProcedureId" asp-items="Model.ProcedureOptions"
                                name="procedureId"
                                hx-get="?handler=Parameters"
                                hx-target="#parameters-panel"
                                hx-swap="innerHTML"
                                hx-include="this">
                        </select>
                        <p id="procedure-selection-hint" class="mt-1 text-xs text-slate-500 @(hasProcedure ? "hidden" : "")">
                            @L["Home_SelectProcedureRequired"]
                        </p>
                    </div>
                    <div class="lg:col-span-2">
                        <label class="qp-label">@L["Description"]</label>
                        <textarea class="qp-input bg-slate-50" rows="2" readonly
                                  id="procedure-description"
                                  name="procedureDescription">@(Model.SelectedProcedure?.Description)</textarea>
                    </div>
                </div>

                <div class="mt-4 grid grid-cols-1 gap-4 xl:grid-cols-12">
                    <div class="xl:col-span-4">
                        <div class="qp-card h-full">
                            <div class="qp-card-header">
                                <h2 class="font-semibold">@L["Home_Parameters"]</h2>
                            </div>
                            <div class="qp-card-body" id="parameters-panel">
                                @if (Model.SelectedProcedure is not null)
                                {
                                    <partial name="Shared/Partials/_ParameterForm" model="Model.SelectedProcedure" />
                                }
                                else
                                {
                                    <p class="text-sm text-slate-500">@L["Home_NoProcedure"]</p>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="xl:col-span-8">
                        <div class="qp-card h-full">
                            <div class="qp-card-header">
                                <h2 class="font-semibold">@L["Home_Results"]</h2>
                                <div id="export-status"></div>
                            </div>
                            <div class="qp-card-body overflow-x-auto" id="results-panel"
                                 data-export-ready="false">
                                <div class="js-results-root" data-export-ready="false" data-row-count="0">
                                    <p class="text-sm text-slate-500">@L["NoRecords"]</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
