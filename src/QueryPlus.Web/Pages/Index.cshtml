@page
@model IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L
@{
    ViewData["Title"] = L["Home_Title"].Value;
    var hasProcedure = Model.ProcedureId is > 0;
}

<div class="qp-page qp-home-page"
     data-msg-select-procedure="@L["Home_SelectProcedureRequired"]"
     data-msg-export-requires-data="@L["Home_ExportRequiresData"]"
     data-msg-required-params="@L["Home_RequiredParametersClient"]"
     data-msg-required-params-multi="@L["Home_RequiredParametersMissing"]">
    <div class="qp-card qp-home-toolbar shrink-0">
        <div class="qp-card-header">
            <h1 class="text-xl font-semibold text-navy">@L["Home_Title"]</h1>
            <div class="flex flex-wrap gap-2">
                <button type="button"
                        id="btn-execute"
                        class="qp-btn-primary"
                        hx-post="?handler=Execute"
                        hx-include="#exec-form"
                        hx-target="#results-panel"
                        hx-swap="innerHTML"
                        hx-indicator="#exec-indicator"
                        disabled="@(!hasProcedure)"
                        title="@L["Home_SelectProcedureRequired"]">
                    @L["Home_Execute"]
                </button>
                <button type="button"
                        id="btn-clear"
                        class="qp-btn-secondary"
                        data-clear-url="@Url.Page("/Index")"
                        disabled="@(!hasProcedure)"
                        title="@L["Home_SelectProcedureRequired"]">
                    @L["Clear"]
                </button>
                <button type="button"
                        id="btn-export"
                        class="qp-btn-accent"
                        hx-post="?handler=Export"
                        hx-include="#exec-form"
                        hx-target="#export-status"
                        hx-swap="innerHTML"
                        disabled="disabled"
                        title="@L["Home_ExportRequiresData"]">
                    @L["Home_Export"]
                </button>
                <span id="exec-indicator" class="htmx-indicator text-sm text-slate-500">…</span>
            </div>
        </div>
    </div>

    @* Enter is intercepted in site.js (prevent full post that wipes procedure list). *@
    <form id="exec-form" method="post" class="js-exec-form qp-home-workspace">
        @Html.AntiForgeryToken()
        <input type="hidden"
               id="procedureId"
               name="procedureId"
               class="js-procedure-select"
               value="@(Model.ProcedureId is > 0 ? Model.ProcedureId.Value.ToString() : "")" />

        <div class="qp-home-columns">
            @* Column 1 (~20%): procedure list (Outlook-style inbox) *@
            <section class="qp-card qp-home-column" aria-label="@L["Home_SelectProcedure"]">
                <div class="qp-card-header qp-home-column-header">
                    <h2 class="font-semibold">@L["Home_SelectProcedure"]</h2>
                    <span class="text-xs font-normal text-slate-500">@Model.AccessibleProcedures.Count</span>
                </div>
                <div id="procedure-list"
                     class="qp-home-column-scroll qp-procedure-list"
                     role="listbox"
                     aria-label="@L["Home_SelectProcedure"]">
                    @if (Model.AccessibleProcedures.Count == 0)
                    {
                        <p class="px-3 py-4 text-sm text-slate-500">@L["NoRecords"]</p>
                    }
                    else
                    {
                        foreach (var proc in Model.AccessibleProcedures)
                        {
                            var selected = Model.ProcedureId == proc.Id;
                            var description = string.IsNullOrWhiteSpace(proc.Description)
                                ? "—"
                                : proc.Description;
                            <button type="button"
                                    role="option"
                                    class="qp-procedure-item js-procedure-item @(selected ? "is-selected" : "")"
                                    data-procedure-id="@proc.Id"
                                    aria-selected="@(selected ? "true" : "false")"
                                    title="@proc.Caption"
                                    hx-get="?handler=Parameters&procedureId=@proc.Id"
                                    hx-target="#parameters-panel"
                                    hx-swap="innerHTML">
                                <span class="qp-procedure-item-caption">@proc.Caption</span>
                                <span class="qp-procedure-item-description">@description</span>
                            </button>
                        }
                    }
                </div>
                <p id="procedure-selection-hint"
                   class="qp-home-column-footer @(hasProcedure ? "hidden" : "")">
                    @L["Home_SelectProcedureRequired"]
                </p>
            </section>

            @* Column 2 (~20%): parameters *@
            <section class="qp-card qp-home-column" aria-label="@L["Home_Parameters"]">
                <div class="qp-card-header qp-home-column-header">
                    <h2 class="font-semibold">@L["Home_Parameters"]</h2>
                </div>
                <div class="qp-card-body qp-home-column-scroll" id="parameters-panel">
                    @if (Model.SelectedProcedure is not null)
                    {
                        <partial name="Shared/Partials/_ParameterForm" model="Model.SelectedProcedure" />
                    }
                    else
                    {
                        <p class="text-sm text-slate-500">@L["Home_NoProcedure"]</p>
                    }
                </div>
            </section>

            @* Column 3 (~60%): results grid *@
            <section class="qp-card qp-home-column qp-home-column-results" aria-label="@L["Home_Results"]">
                <div class="qp-card-header qp-home-column-header">
                    <h2 class="font-semibold">@L["Home_Results"]</h2>
                    <div id="export-status"></div>
                </div>
                <div class="qp-card-body qp-home-column-scroll" id="results-panel"
                     data-export-ready="false">
                    <div class="js-results-root" data-export-ready="false" data-row-count="0">
                        <p class="text-sm text-slate-500">@L["NoRecords"]</p>
                    </div>
                </div>
            </section>
        </div>
    </form>
</div>
