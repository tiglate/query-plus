@page
@model IndexModel
@using Microsoft.Extensions.Localization
@using QueryPlus.Web.Resources
@inject IStringLocalizer<SharedResource> L
@{
    ViewData["Title"] = L["Home_Title"].Value;
}

<div class="space-y-6">
    <section class="rounded-xl border border-slate-200 bg-white p-8 shadow-sm">
        <h1 class="text-3xl font-bold tracking-tight text-slate-900">@L["Home_Welcome"]</h1>
        <p class="mt-3 max-w-2xl text-slate-600">
            @L["Home_Description"]
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
            <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-medium text-indigo-700">.NET 10</span>
            <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-medium text-emerald-700">EF Core</span>
            <span class="rounded-full bg-amber-50 px-3 py-1 text-xs font-medium text-amber-700">Dapper</span>
            <span class="rounded-full bg-sky-50 px-3 py-1 text-xs font-medium text-sky-700">Keycloak</span>
            <span class="rounded-full bg-fuchsia-50 px-3 py-1 text-xs font-medium text-fuchsia-700">HTMX + Tailwind</span>
        </div>
    </section>

    <section class="grid gap-4 md:grid-cols-2" hx-boost="true">
        <div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
            <h2 class="font-semibold text-slate-800">@L["Home_Architecture"]</h2>
            <p class="mt-2 text-sm text-slate-600">@L["Home_Architecture_Body"]</p>
        </div>
        <div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
            <h2 class="font-semibold text-slate-800">@L["Home_Auth"]</h2>
            <p class="mt-2 text-sm text-slate-600">@L["Home_Auth_Body"]</p>
        </div>
    </section>
</div>
