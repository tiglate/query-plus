@using Microsoft.Extensions.Localization
@using QueryPlus.Web.Resources
@inject IStringLocalizer<SharedResource> L
@{
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name;
    var path = Context.Request.Path.Value ?? "/";
}
<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QueryPlus</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
          crossorigin="anonymous"
          referrerpolicy="no-referrer" />
    @* Clusterize CSS first; site.css overrides its default max-height:200px on the scroll area. *@
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/clusterize.js/0.19.0/clusterize.min.css"
          crossorigin="anonymous"
          referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://unpkg.com/htmx.org@2.0.4" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/clusterize.js/0.19.0/clusterize.min.js"
            crossorigin="anonymous"
            referrerpolicy="no-referrer"></script>
    <script src="~/js/sheet-grid.js" asp-append-version="true"></script>
    @inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
    @{
        var af = Antiforgery.GetAndStoreTokens(Context);
    }
    <meta name="csrf-token" content="@af.RequestToken" />
</head>
@* h-dvh + overflow-hidden: chrome stays fixed; main scrolls for admin pages; home fills main and scrolls per-column. *@
<body class="flex h-dvh flex-col overflow-hidden font-sans">
    <header class="shrink-0 bg-navy text-white shadow">
        <div class="flex w-full items-center justify-between gap-3 px-3 py-2 lg:px-4">
            <div class="flex items-center gap-6">
                <a asp-page="/Index" class="flex items-center gap-2 text-sm font-semibold tracking-tight">
                    <span class="inline-flex h-7 w-7 items-center justify-center rounded bg-cyan text-xs font-bold text-navy">Q+</span>
                    <span>QueryPlus</span>
                </a>
                <nav class="hidden items-center gap-0.5 md:flex">
                    <a asp-page="/Index"
                       class="qp-nav-link @(path == "/" ? "bg-white/10 text-cyan" : "")">
                        <i class="fa-solid fa-house" aria-hidden="true"></i>
                        @L["Nav_Home"]
                    </a>
                    @* JS-managed dropdown (CSS hover alone fails across the button→menu gap). *@
                    <div class="qp-nav-dropdown relative" data-nav-dropdown>
                        <button type="button"
                                class="qp-nav-link @(path.StartsWith("/Admin") ? "bg-white/10 text-cyan" : "")"
                                data-nav-dropdown-trigger
                                aria-haspopup="true"
                                aria-expanded="false"
                                id="nav-admin-trigger">
                            <i class="fa-solid fa-gear" aria-hidden="true"></i>
                            @L["Nav_Admin"]
                            <i class="fa-solid fa-chevron-down text-[0.65rem] opacity-80" aria-hidden="true"></i>
                        </button>
                        <div class="qp-nav-dropdown-panel absolute left-0 top-full z-50 w-48 pt-1"
                             data-nav-dropdown-panel
                             role="menu"
                             aria-labelledby="nav-admin-trigger"
                             hidden>
                            <div class="rounded-md border border-slate-200 bg-white py-1 text-navy shadow-lg">
                                <a asp-page="/Admin/Categories/Index"
                                   role="menuitem"
                                   class="flex items-center gap-2 px-3 py-1.5 text-sm hover:bg-cyan-50">
                                    <i class="fa-solid fa-folder text-slate-500" aria-hidden="true"></i>
                                    @L["Nav_Categories"]
                                </a>
                                <a asp-page="/Admin/Procedures/Index"
                                   role="menuitem"
                                   class="flex items-center gap-2 px-3 py-1.5 text-sm hover:bg-cyan-50">
                                    <i class="fa-solid fa-database text-slate-500" aria-hidden="true"></i>
                                    @L["Nav_Procedures"]
                                </a>
                            </div>
                        </div>
                    </div>
                    <a asp-page="/Support"
                       class="qp-nav-link @(path.StartsWith("/Support") ? "bg-white/10 text-cyan" : "")">
                        <i class="fa-solid fa-life-ring" aria-hidden="true"></i>
                        @L["Nav_Support"]
                    </a>
                </nav>
            </div>
            <div class="flex items-center gap-2">
                <form method="post" asp-page="/Culture" class="flex items-center gap-1.5 text-sm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@($"{Context.Request.Path}{Context.Request.QueryString}")" />
                    <label class="sr-only" for="culture">@L["Language"]</label>
                    <i class="fa-solid fa-globe text-white/80" aria-hidden="true" title="@L["Language"]"></i>
                    @* Options must use dark text: browsers inherit select color into the popup list. *@
                    <select id="culture" name="culture" class="qp-lang-select"
                            onchange="this.form.submit()">
                        @if (culture.StartsWith("pt", StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="pt-BR" selected>Português</option>
                            <option value="en">English</option>
                        }
                        else
                        {
                            <option value="pt-BR">Português</option>
                            <option value="en" selected>English</option>
                        }
                    </select>
                </form>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="hidden items-center gap-1.5 text-sm text-white/80 sm:inline-flex">
                        <i class="fa-solid fa-user" aria-hidden="true"></i>
                        @User.Identity.Name
                    </span>
                    <form method="post" action="/Account/Logout">
                        <button type="submit" class="qp-header-btn inline-flex items-center gap-1.5 rounded px-2.5 py-1 text-sm font-medium">
                            <i class="fa-solid fa-right-from-bracket" aria-hidden="true"></i>
                            @L["Logout"]
                        </button>
                    </form>
                }
                else
                {
                    <a href="/Account/Login" class="qp-header-btn qp-header-btn-login inline-flex items-center gap-1.5 rounded px-2.5 py-1 text-sm font-semibold text-navy">
                        <i class="fa-solid fa-right-to-bracket" aria-hidden="true"></i>
                        @L["Login"]
                    </a>
                }
            </div>
        </div>
    </header>

    <main class="flex min-h-0 w-full flex-1 flex-col overflow-y-auto">
        @if (TempData["Success"] is string success)
        {
            <div class="mx-3 mt-3 shrink-0 rounded border border-leaf bg-leaf/20 px-3 py-1.5 text-xs text-navy lg:mx-4">
                <i class="fa-solid fa-circle-check mr-1" aria-hidden="true"></i>@success
            </div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="mx-3 mt-3 shrink-0 rounded border border-red-300 bg-red-50 px-3 py-1.5 text-xs text-red-800 lg:mx-4">
                <i class="fa-solid fa-circle-exclamation mr-1" aria-hidden="true"></i>@error
            </div>
        }
        @RenderBody()
    </main>

    <footer class="shrink-0 border-t border-slate-200 bg-white">
        <div class="flex w-full items-center justify-between px-3 py-2 text-[11px] text-slate-500 lg:px-4">
            <span>&copy; @DateTime.UtcNow.Year QueryPlus</span>
            <span>@L["Footer_Tagline"]</span>
        </div>
    </footer>

    @* ClientApp shell (Vite → wwwroot/dist): nav dropdown, confirm forms, CSRF. *@
    <script type="module" src="~/dist/js/app.js" asp-append-version="true"></script>
    @* Legacy home/admin helpers until Phase 3–6 migration completes. *@
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
