@model ExecutionResultDto
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L
@{
    var hasRows = Model.Success && Model.Data is { Rows.Count: > 0 };
    var rowCount = hasRows ? Model.Data!.Rows.Count : 0;
    var supportsPagination = Model.SupportsPagination;
    var totalRecords = supportsPagination
        ? Model.TotalRecords ?? rowCount
        : rowCount;
    var pageNumber = Model.PageNumber > 0 ? Model.PageNumber : 1;
    var pageSize = Model.PageSize > 0 ? Model.PageSize : 50L;
    var totalPages = pageSize > 0 && totalRecords > 0
        ? (int)Math.Ceiling(totalRecords / (double)pageSize)
        : 0;

    var visibleColumns = new List<(string Caption, string Align, string? FormatMask, int SourceIndex)>();
    if (hasRows)
    {
        for (var i = 0; i < Model.Data!.Columns.Count; i++)
        {
            var col = Model.Data.Columns[i];
            var meta = Model.Columns.FirstOrDefault(c =>
                string.Equals(c.TechnicalName, col.ColumnName, StringComparison.OrdinalIgnoreCase));
            if (meta is { Visible: false })
            {
                continue;
            }

            var caption = meta?.Caption ?? col.ColumnName;
            var align = meta?.Alignment switch
            {
                ColumnAlignment.Center => "center",
                ColumnAlignment.Right => "right",
                _ => "left"
            };
            visibleColumns.Add((caption, align, meta?.FormatMask, i));
        }
    }

    string FormatCell(object? value, string? formatMask)
    {
        if (value is DBNull or null)
        {
            return "";
        }

        var text = value.ToString() ?? "";
        if (formatMask is { Length: > 0 } && value is IFormattable formattable)
        {
            try
            {
                text = string.Format(System.Globalization.CultureInfo.CurrentCulture, formatMask, formattable);
            }
            catch
            {
                // keep raw text
            }
        }

        return text;
    }

    SheetGridModel? sheet = null;
    if (hasRows)
    {
        var cells = new List<IReadOnlyList<string>>(rowCount);
        foreach (System.Data.DataRow row in Model.Data!.Rows)
        {
            var values = new string[visibleColumns.Count];
            for (var c = 0; c < visibleColumns.Count; c++)
            {
                values[c] = FormatCell(row[visibleColumns[c].SourceIndex], visibleColumns[c].FormatMask);
            }

            cells.Add(values);
        }

        var metaText = supportsPagination && totalRecords > 0
            ? string.Format(L["Pagination_Summary"].Value,
                ((pageNumber - 1) * pageSize) + 1,
                Math.Min(pageNumber * pageSize, totalRecords),
                totalRecords)
            : $"{Model.RowCount} {L["Home_Rows"].Value}";

        sheet = new SheetGridModel
        {
            Columns = visibleColumns
                .Select(c => new SheetGridColumn
                {
                    Caption = c.Caption,
                    Align = c.Align
                })
                .ToList(),
            Cells = cells,
            EmptyMessage = L["NoRecords"].Value,
            MetaText = metaText,
            ShowInteractionHint = true,
            CssClass = "qp-sheet-grid--home"
        };
    }

    // Export is allowed when the full dataset has rows (paginated total or current page).
    var exportReady = Model.Success && (
        (supportsPagination && totalRecords > 0) ||
        hasRows);

    // hx-vals must carry pageNumber: form hidden fields are serialized before configRequest
    // can update the DOM, so without hx-vals every page click re-posts page 1.
    // Use $$""" so a single { is literal JSON; interpolations are {{name}}.
    string PageButton(long page, string css, string content, bool disabled = false)
    {
        if (disabled)
        {
            return $$"""<span class="{{css}} pointer-events-none opacity-50">{{content}}</span>""";
        }

        return $$"""
            <button type="button"
                    class="{{css}} js-results-page"
                    data-page="{{page}}"
                    hx-post="?handler=Execute"
                    hx-include="#exec-form"
                    hx-vals='{"pageNumber":"{{page}}"}'
                    hx-target="#results-panel"
                    hx-swap="innerHTML"
                    hx-indicator="#exec-indicator">
                {{content}}
            </button>
            """;
    }

    var showPager = supportsPagination && totalRecords > 0 && sheet is not null;
}

<div class="js-results-root js-sheet-host@(showPager ? " has-results-footer" : "")"
     data-export-ready="@(exportReady ? "true" : "false")"
     data-row-count="@rowCount"
     data-total-records="@totalRecords"
     data-supports-pagination="@(supportsPagination ? "true" : "false")"
     data-page-number="@pageNumber"
     data-page-size="@pageSize"
     data-procedure-id="@Model.ProcedureId"
     data-col-count="@visibleColumns.Count">
@if (!Model.Success)
{
    <div class="qp-results-body">
        <div class="rounded border border-red-200 bg-red-50 px-3 py-2 text-xs text-red-800">
            <i class="fa-solid fa-circle-exclamation" aria-hidden="true"></i>
            @(Model.ErrorMessage ?? L["Home_ExportFailed"].Value)
        </div>
    </div>
}
else if (sheet is null)
{
    <div class="qp-results-body">
        <p class="qp-results-empty text-xs text-slate-500">@L["NoRecords"]</p>
    </div>
}
else
{
    <div class="qp-results-body">
        <partial name="Shared/Partials/_SheetGrid" model="sheet" />
    </div>

    @if (showPager)
    {
        <footer class="qp-results-card-footer qp-home-results-pager"
                aria-label="@L["Pagination"]"
                data-page-number="@pageNumber"
                data-page-size="@pageSize"
                data-total-pages="@totalPages">
            <p class="text-xs text-slate-600 dark:text-slate-400">
                @string.Format(L["Pagination_Summary"].Value,
                    ((pageNumber - 1) * pageSize) + 1,
                    Math.Min(pageNumber * pageSize, totalRecords),
                    totalRecords)
            </p>

            @if (totalPages > 1)
            {
                var prevPage = pageNumber - 1;
                var nextPage = pageNumber + 1;
                var windowStart = Math.Max(1, (int)pageNumber - 2);
                var windowEnd = Math.Min(totalPages, (int)pageNumber + 2);

                <div class="flex flex-wrap items-center gap-1">
                    @Html.Raw(PageButton(
                        prevPage,
                        "qp-btn-secondary !px-2 !py-1",
                        $"<i class=\"fa-solid fa-chevron-left\" aria-hidden=\"true\"></i> {L["Pagination_Previous"].Value}",
                        pageNumber <= 1))

                    @if (windowStart > 1)
                    {
                        @Html.Raw(PageButton(1, "qp-btn-ghost !px-2 !py-1", "1"))
                        if (windowStart > 2)
                        {
                            <span class="px-1 text-slate-400">…</span>
                        }
                    }

                    @for (var p = windowStart; p <= windowEnd; p++)
                    {
                        if (p == pageNumber)
                        {
                            <span class="inline-flex items-center justify-center rounded-md bg-navy px-2 py-1 text-xs font-medium text-white"
                                  aria-current="page">@p</span>
                        }
                        else
                        {
                            @Html.Raw(PageButton(p, "qp-btn-ghost !px-2 !py-1", p.ToString()))
                        }
                    }

                    @if (windowEnd < totalPages)
                    {
                        if (windowEnd < totalPages - 1)
                        {
                            <span class="px-1 text-slate-400">…</span>
                        }
                        @Html.Raw(PageButton(totalPages, "qp-btn-ghost !px-2 !py-1", totalPages.ToString()))
                    }

                    @Html.Raw(PageButton(
                        nextPage,
                        "qp-btn-secondary !px-2 !py-1",
                        $"{L["Pagination_Next"].Value} <i class=\"fa-solid fa-chevron-right\" aria-hidden=\"true\"></i>",
                        pageNumber >= totalPages))
                </div>
            }
        </footer>
    }
}
</div>
