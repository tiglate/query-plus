@model ExecutionResultDto
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L
@{
    var hasRows = Model.Success && Model.Data is { Rows.Count: > 0 };
    var rowCount = hasRows ? Model.Data!.Rows.Count : 0;
}

<div class="js-results-root"
     data-export-ready="@(hasRows ? "true" : "false")"
     data-row-count="@rowCount"
     data-procedure-id="@Model.ProcedureId">
@if (!Model.Success)
{
    <div class="rounded border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800">
        @(Model.ErrorMessage ?? L["Home_ExportFailed"].Value)
    </div>
}
else if (!hasRows)
{
    <p class="text-sm text-slate-500">@L["NoRecords"]</p>
}
else
{
    <div class="mb-2 text-sm text-slate-600">@Model.RowCount @L["Home_Rows"]</div>
    <div class="max-h-[70vh] overflow-auto">
        <table class="qp-table" id="results-table">
            <thead class="sticky top-0">
                <tr>
                    @{
                        var colIndex = 0;
                    }
                    @foreach (System.Data.DataColumn col in Model.Data!.Columns)
                    {
                        var meta = Model.Columns.FirstOrDefault(c =>
                            string.Equals(c.TechnicalName, col.ColumnName, StringComparison.OrdinalIgnoreCase));
                        if (meta is { Visible: false })
                        {
                            colIndex++;
                            continue;
                        }
                        var caption = meta?.Caption ?? col.ColumnName;
                        var align = meta?.Alignment switch
                        {
                            ColumnAlignment.Center => "center",
                            ColumnAlignment.Right => "right",
                            _ => "left"
                        };
                        <th data-sort-col="@colIndex" class="cursor-pointer select-none" style="text-align:@align" title="Sort">
                            @caption
                        </th>
                        colIndex++;
                    }
                </tr>
            </thead>
            <tbody>
            @foreach (System.Data.DataRow row in Model.Data.Rows)
            {
                <tr>
                    @for (var i = 0; i < Model.Data.Columns.Count; i++)
                    {
                        var col = Model.Data.Columns[i];
                        var meta = Model.Columns.FirstOrDefault(c =>
                            string.Equals(c.TechnicalName, col.ColumnName, StringComparison.OrdinalIgnoreCase));
                        if (meta is { Visible: false })
                        {
                            continue;
                        }
                        var value = row[i];
                        var text = value is DBNull or null ? "" : value.ToString();
                        if (meta?.FormatMask is { Length: > 0 } mask && value is IFormattable)
                        {
                            try
                            {
                                text = string.Format(System.Globalization.CultureInfo.CurrentCulture, mask, value);
                            }
                            catch
                            {
                                // keep raw text
                            }
                        }
                        var align = meta?.Alignment switch
                        {
                            ColumnAlignment.Center => "center",
                            ColumnAlignment.Right => "right",
                            _ => "left"
                        };
                        <td class="whitespace-nowrap" style="text-align:@align">@text</td>
                    }
                </tr>
            }
            </tbody>
        </table>
    </div>
}
</div>
