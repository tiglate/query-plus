@model ExecutionResultDto
@using System.Text.Json
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L
@{
    var hasRows = Model.Success && Model.Data is { Rows.Count: > 0 };
    var rowCount = hasRows ? Model.Data!.Rows.Count : 0;

    // Visible columns (metadata may hide technical columns).
    var visibleColumns = new List<(string Caption, string Align, string? FormatMask, int SourceIndex)>();
    if (hasRows)
    {
        for (var i = 0; i < Model.Data!.Columns.Count; i++)
        {
            var col = Model.Data.Columns[i];
            var meta = Model.Columns.FirstOrDefault(c =>
                string.Equals(c.TechnicalName, col.ColumnName, StringComparison.OrdinalIgnoreCase));
            if (meta is { Visible: false })
            {
                continue;
            }

            var caption = meta?.Caption ?? col.ColumnName;
            var align = meta?.Alignment switch
            {
                ColumnAlignment.Center => "center",
                ColumnAlignment.Right => "right",
                _ => "left"
            };
            visibleColumns.Add((caption, align, meta?.FormatMask, i));
        }
    }

    string FormatCell(object? value, string? formatMask)
    {
        if (value is DBNull or null)
        {
            return "";
        }

        var text = value.ToString() ?? "";
        if (formatMask is { Length: > 0 } && value is IFormattable formattable)
        {
            try
            {
                text = string.Format(System.Globalization.CultureInfo.CurrentCulture, formatMask, formattable);
            }
            catch
            {
                // keep raw text
            }
        }

        return text;
    }

    // Structured payload: client builds row HTML, auto-sizes, reorders, and resizes.
    var columnsPayload = visibleColumns
        .Select(c => new { caption = c.Caption, align = c.Align })
        .ToList();

    var cellValues = new List<string[]>(rowCount);
    if (hasRows)
    {
        foreach (System.Data.DataRow row in Model.Data!.Rows)
        {
            var values = new string[visibleColumns.Count];
            for (var c = 0; c < visibleColumns.Count; c++)
            {
                values[c] = FormatCell(row[visibleColumns[c].SourceIndex], visibleColumns[c].FormatMask);
            }

            cellValues.Add(values);
        }
    }

    // Prevent accidental </script> breakout in the HTML document.
    var payloadJson = JsonSerializer.Serialize(new { columns = columnsPayload, cells = cellValues })
        .Replace("</", "<\\/", StringComparison.Ordinal);
}

<div class="js-results-root"
     data-export-ready="@(hasRows ? "true" : "false")"
     data-row-count="@rowCount"
     data-procedure-id="@Model.ProcedureId"
     data-col-count="@visibleColumns.Count">
@if (!Model.Success)
{
    <div class="rounded border border-red-200 bg-red-50 px-3 py-2 text-xs text-red-800">
        <i class="fa-solid fa-circle-exclamation" aria-hidden="true"></i>
        @(Model.ErrorMessage ?? L["Home_ExportFailed"].Value)
    </div>
}
else if (!hasRows)
{
    <p class="qp-results-empty text-xs text-slate-500">@L["NoRecords"]</p>
}
else
{
    <div class="qp-results-meta shrink-0">
        <span class="qp-results-meta-count">@Model.RowCount @L["Home_Rows"]</span>
        <span class="qp-results-meta-hint">
            <i class="fa-solid fa-up-down-left-right" aria-hidden="true"></i>
            Drag headers to reorder · Drag edges to resize
        </span>
    </div>

    @* Clusterize.js: header table + virtualized scroll body. Headers rebuilt client-side. *@
    <div class="clusterize qp-results-clusterize">
        <div class="clusterize-headers qp-results-headers">
            <table class="qp-sheet js-results-headers-table">
                <colgroup class="js-results-colgroup-header"></colgroup>
                <thead>
                    <tr class="js-results-header-row"></tr>
                </thead>
            </table>
        </div>
        <div class="clusterize-scroll qp-results-scroll js-results-scroll">
            <table class="qp-sheet js-results-body-table">
                <colgroup class="js-results-colgroup-body"></colgroup>
                <tbody class="clusterize-content js-results-content">
                    <tr class="clusterize-no-data">
                        <td class="qp-sheet-cell" colspan="@Math.Max(visibleColumns.Count, 1)">@L["NoRecords"]</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <script type="application/json" class="js-results-data">@Html.Raw(payloadJson)</script>
}
</div>
