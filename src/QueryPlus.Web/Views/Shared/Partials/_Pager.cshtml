@model QueryPlus.Web.Models.PagerModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L
@{
    if (Model.TotalCount == 0)
    {
        return;
    }

    Dictionary<string, string> PageRoute(int page)
    {
        var dict = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            ["pageNumber"] = page.ToString()
        };
        foreach (var kv in Model.RouteValues)
        {
            if (string.IsNullOrEmpty(kv.Value))
            {
                continue;
            }

            dict[kv.Key] = kv.Value;
        }

        return dict;
    }

    var visible = Model.VisiblePages().ToList();
    var firstVisible = visible.Count > 0 ? visible[0] : 0;
    var lastVisible = visible.Count > 0 ? visible[^1] : 0;
}

<nav class="flex w-full flex-wrap items-center justify-between gap-2" aria-label="@L["Pagination"]">
    <p class="text-xs text-slate-600 dark:text-slate-400">
        @string.Format(L["Pagination_Summary"].Value, Model.FromItem, Model.ToItem, Model.TotalCount)
    </p>

    @if (Model.TotalPages > 1)
    {
        <div class="flex flex-wrap items-center gap-1">
            @if (Model.HasPrevious)
            {
                <a class="qp-btn-secondary !px-2 !py-1"
                   asp-controller="@Model.Controller"
                   asp-action="@Model.Action"
                   asp-all-route-data="PageRoute(Model.Page - 1)">
                    <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
                    @L["Pagination_Previous"]
                </a>
            }
            else
            {
                <span class="qp-btn-secondary pointer-events-none !px-2 !py-1 opacity-50">
                    <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
                    @L["Pagination_Previous"]
                </span>
            }

            @if (firstVisible > 1)
            {
                <a class="qp-btn-ghost !px-2 !py-1"
                   asp-controller="@Model.Controller"
                   asp-action="@Model.Action"
                   asp-all-route-data="PageRoute(1)">1</a>
                @if (firstVisible > 2)
                {
                    <span class="px-1 text-slate-400">…</span>
                }
            }

            @foreach (var p in visible)
            {
                if (p == Model.Page)
                {
                    <span class="inline-flex items-center justify-center rounded-md bg-navy px-2 py-1 text-xs font-medium text-white"
                          aria-current="page">@p</span>
                }
                else
                {
                    <a class="qp-btn-ghost !px-2 !py-1"
                       asp-controller="@Model.Controller"
                       asp-action="@Model.Action"
                       asp-all-route-data="PageRoute(p)">@p</a>
                }
            }

            @if (lastVisible > 0 && lastVisible < Model.TotalPages)
            {
                if (lastVisible < Model.TotalPages - 1)
                {
                    <span class="px-1 text-slate-400">…</span>
                }
                <a class="qp-btn-ghost !px-2 !py-1"
                   asp-controller="@Model.Controller"
                   asp-action="@Model.Action"
                   asp-all-route-data="PageRoute(Model.TotalPages)">@Model.TotalPages</a>
            }

            @if (Model.HasNext)
            {
                <a class="qp-btn-secondary !px-2 !py-1"
                   asp-controller="@Model.Controller"
                   asp-action="@Model.Action"
                   asp-all-route-data="PageRoute(Model.Page + 1)">
                    @L["Pagination_Next"]
                    <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
                </a>
            }
            else
            {
                <span class="qp-btn-secondary pointer-events-none !px-2 !py-1 opacity-50">
                    @L["Pagination_Next"]
                    <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
                </span>
            }
        </div>
    }
</nav>
