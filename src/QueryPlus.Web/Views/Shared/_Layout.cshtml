@using Microsoft.Extensions.Localization
@using QueryPlus.Web.Resources
@using QueryPlus.Web.Services
@inject IStringLocalizer<SharedResource> L
@inject DatabaseConnectionDisplay DbConnection
@{
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name;
    var path = Context.Request.Path.Value ?? "/";
}
<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QueryPlus</title>
    @*
      Apply theme before CSS paint to avoid FOUC.
      Key + values must stay in sync with ClientApp ThemeService (qp-theme).
    *@
    <script>
        (function () {
            try {
                var key = "qp-theme";
                var pref = localStorage.getItem(key) || "system";
                if (pref !== "light" && pref !== "dark" && pref !== "system") pref = "system";
                var dark = pref === "dark" || (pref === "system" && window.matchMedia("(prefers-color-scheme: dark)").matches);
                var root = document.documentElement;
                root.classList.toggle("dark", dark);
                root.style.colorScheme = dark ? "dark" : "light";
                root.dataset.theme = pref;
                root.dataset.themeResolved = dark ? "dark" : "light";
            } catch (e) { /* private mode */ }
        })();
    </script>
    @* ClientApp build (Vite): CSS includes Tailwind, Clusterize, Font Awesome, Inter (no CDNs). *@
    <link rel="stylesheet" href="~/dist/css/site.css" asp-append-version="true" />
    @inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
    @{
        var af = Antiforgery.GetAndStoreTokens(Context);
    }
    <meta name="csrf-token" content="@af.RequestToken" />
    @* Preferred page key for ClientApp (set in page models / views via ViewData["PageKey"]). *@
    <meta name="qp-page" content="@(ViewData["PageKey"] as string ?? "")" />
</head>
@* h-dvh + overflow-hidden: chrome stays fixed; main scrolls for admin pages; home fills main and scrolls per-column. *@
@* data-page on body is secondary; meta[name=qp-page] is primary for ClientApp routing. *@
<body class="flex h-dvh flex-col overflow-hidden font-sans"
      data-page="@(ViewData["PageKey"] as string ?? "")">
    @* Global ajax activity indicator (any htmx request); see ClientApp LoadingBarService. Purely visual. *@
    <div id="qp-loading-bar" class="qp-loading-bar" aria-hidden="true"></div>
    <header class="shrink-0 bg-navy text-white shadow">
        <div class="flex w-full items-center justify-between gap-3 px-3 py-2 lg:px-4">
            <div class="flex items-center gap-6">
                <a asp-controller="Home" asp-action="Index" class="flex items-center gap-2 text-sm font-semibold tracking-tight">
                    <span class="inline-flex h-7 w-7 items-center justify-center rounded bg-cyan text-xs font-bold text-navy">Q+</span>
                    <span>QueryPlus</span>
                </a>
                <nav class="hidden items-center gap-0.5 md:flex">
                    <a asp-controller="Home" asp-action="Index"
                       class="qp-nav-link @(path == "/" ? "bg-white/10 text-cyan" : "")">
                        <i class="fa-solid fa-house" aria-hidden="true"></i>
                        @L["Nav_Home"]
                    </a>
                    @* JS-managed dropdown (CSS hover alone fails across the button→menu gap). *@
                    <div class="qp-nav-dropdown relative" data-nav-dropdown>
                        <button type="button"
                                class="qp-nav-link @(path.StartsWith("/Admin") ? "bg-white/10 text-cyan" : "")"
                                data-nav-dropdown-trigger
                                aria-haspopup="true"
                                aria-expanded="false"
                                id="nav-admin-trigger">
                            <i class="fa-solid fa-gear" aria-hidden="true"></i>
                            @L["Nav_Admin"]
                            <i class="fa-solid fa-chevron-down text-[0.65rem] opacity-80" aria-hidden="true"></i>
                        </button>
                        <div class="qp-nav-dropdown-panel absolute left-0 top-full z-50 w-48 pt-1"
                             data-nav-dropdown-panel
                             role="menu"
                             aria-labelledby="nav-admin-trigger"
                             hidden>
                            <div class="rounded-md border border-slate-200 bg-white py-1 text-navy shadow-lg dark:border-navy-600 dark:bg-navy-800 dark:text-slate-100">
                                <a asp-controller="Categories" asp-action="Index"
                                   role="menuitem"
                                   class="flex items-center gap-2 px-3 py-1.5 text-sm hover:bg-cyan-50 dark:hover:bg-navy-700">
                                    <i class="fa-solid fa-folder text-slate-500 dark:text-slate-400" aria-hidden="true"></i>
                                    @L["Nav_Categories"]
                                </a>
                                <a asp-controller="Procedures" asp-action="Index"
                                   role="menuitem"
                                   class="flex items-center gap-2 px-3 py-1.5 text-sm hover:bg-cyan-50 dark:hover:bg-navy-700">
                                    <i class="fa-solid fa-database text-slate-500 dark:text-slate-400" aria-hidden="true"></i>
                                    @L["Nav_Procedures"]
                                </a>
                            </div>
                        </div>
                    </div>
                    <a asp-controller="Support" asp-action="Index"
                       class="qp-nav-link @(path.StartsWith("/Support") ? "bg-white/10 text-cyan" : "")">
                        <i class="fa-solid fa-life-ring" aria-hidden="true"></i>
                        @L["Nav_Support"]
                    </a>
                </nav>
            </div>
            <div class="flex items-center gap-2">
                @* Theme: Light / Dark / System (default). Wired by ClientApp ThemeService. *@
                <div class="flex items-center gap-1.5 text-sm" data-theme-control>
                    <label class="sr-only" for="theme-preference">@L["Theme"]</label>
                    <i class="fa-solid fa-circle-half-stroke text-white/80"
                       data-theme-icon
                       aria-hidden="true"
                       title="@L["Theme"]"></i>
                    <select id="theme-preference"
                            class="qp-lang-select"
                            data-theme-select
                            aria-label="@L["Theme"]">
                        <option value="system">@L["Theme_System"]</option>
                        <option value="light">@L["Theme_Light"]</option>
                        <option value="dark">@L["Theme_Dark"]</option>
                    </select>
                </div>
                <form method="post" asp-controller="Culture" asp-action="Set" class="flex items-center gap-1.5 text-sm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@($"{Context.Request.Path}{Context.Request.QueryString}")" />
                    <label class="sr-only" for="culture">@L["Language"]</label>
                    <i class="fa-solid fa-globe text-white/80" aria-hidden="true" title="@L["Language"]"></i>
                    @* Options must use dark text: browsers inherit select color into the popup list. *@
                    <select id="culture" name="culture" class="qp-lang-select"
                            onchange="this.form.submit()">
                        @if (culture.StartsWith("pt", StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="pt-BR" selected>Português</option>
                            <option value="en">English</option>
                        }
                        else
                        {
                            <option value="pt-BR">Português</option>
                            <option value="en" selected>English</option>
                        }
                    </select>
                </form>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="hidden items-center gap-1.5 text-sm text-white/80 sm:inline-flex">
                        <i class="fa-solid fa-user" aria-hidden="true"></i>
                        @User.Identity.Name
                    </span>
                    @* FormTagHelper injects the antiforgery token automatically. *@
                    <form method="post" asp-controller="Account" asp-action="Logout">
                        <button type="submit" class="qp-header-btn inline-flex items-center gap-1.5 rounded px-2.5 py-1 text-sm font-medium">
                            <i class="fa-solid fa-right-from-bracket" aria-hidden="true"></i>
                            @L["Logout"]
                        </button>
                    </form>
                }
                else
                {
                    <a href="/Account/Login" class="qp-header-btn qp-header-btn-login inline-flex items-center gap-1.5 rounded px-2.5 py-1 text-sm font-semibold text-navy">
                        <i class="fa-solid fa-right-to-bracket" aria-hidden="true"></i>
                        @L["Login"]
                    </a>
                }
            </div>
        </div>
    </header>

    <main class="flex min-h-0 w-full flex-1 flex-col overflow-y-auto bg-slate-100 dark:bg-navy-900">
        @if (TempData["Success"] is string success)
        {
            <div class="mx-3 mt-3 shrink-0 rounded border border-leaf bg-leaf/20 px-3 py-1.5 text-xs text-navy dark:border-leaf/40 dark:bg-leaf/15 dark:text-slate-100 lg:mx-4">
                <i class="fa-solid fa-circle-check mr-1" aria-hidden="true"></i>@success
            </div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="mx-3 mt-3 shrink-0 rounded border border-red-300 bg-red-50 px-3 py-1.5 text-xs text-red-800 dark:border-red-700 dark:bg-red-950/50 dark:text-red-200 lg:mx-4">
                <i class="fa-solid fa-circle-exclamation mr-1" aria-hidden="true"></i>@error
            </div>
        }
        @RenderBody()
    </main>

    <footer class="shrink-0 border-t border-slate-200 bg-white dark:border-navy-600 dark:bg-navy-800">
        <div class="flex w-full flex-wrap items-center justify-between gap-x-3 gap-y-1 px-3 py-2 text-[11px] text-slate-500 dark:text-slate-400 lg:px-4">
            <span>&copy; @DateTime.UtcNow.Year QueryPlus</span>
            <span class="inline-flex items-center gap-1 font-mono tabular-nums"
                  title="@L["Footer_DatabaseServer"]: @DbConnection.Server · @L["Footer_Database"]: @DbConnection.Database">
                <i class="fa-solid fa-database text-[10px] opacity-70" aria-hidden="true"></i>
                <span class="sr-only">@L["Footer_DatabaseServer"]</span>
                @DbConnection.FooterLabel
            </span>
            <span>@L["Footer_Tagline"]</span>
        </div>
    </footer>

    @*
      ClientApp shell (Vite → wwwroot/dist): nav, confirm, CSRF, SheetGrid, page controllers.
      Built as a single ESM entry (inlineDynamicImports) so MapStaticAssets fingerprinting
      of this URL is safe — no async chunk re-imports "./app.js" as a second module instance.
    *@
    <script type="module" src="~/dist/js/app.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
