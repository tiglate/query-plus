@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> L
@model QueryPlus.Web.Controllers.Admin.CategoriesController.CategoryInputModel
@{
    ViewData["Title"] = L["Categories_New"].Value;
}

<div class="qp-page space-y-4">
    <div class="qp-card">
        <div class="qp-card-header">
            <h1 class="qp-page-title">
                <i class="fa-solid fa-folder-plus text-cyan" aria-hidden="true"></i>
                @L["Categories_New"]
            </h1>
            <div class="flex flex-wrap items-center justify-end gap-1.5">
                <button type="submit" form="category-form" class="qp-btn-primary">
                    <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                    @L["Save"]
                </button>
                <a asp-controller="Categories" asp-action="Index" class="qp-btn-secondary">
                    <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                    @L["Cancel"]
                </a>
                <a asp-controller="Categories" asp-action="Index" class="qp-btn-secondary">
                    <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
                    @L["Back"]
                </a>
            </div>
        </div>
    </div>

    <div class="qp-card">
        <div class="qp-card-header">
            <h2 class="qp-section-title">
                <i class="fa-solid fa-folder" aria-hidden="true"></i>
                @L["Categories_Title"]
            </h2>
        </div>
        <div class="qp-card-body">
            @* Form must include antiforgery; Save uses form="category-form" from the toolbar. *@
            <form id="category-form" method="post" asp-controller="Categories" asp-action="Create">
                <div class="qp-category-description">
                    <label class="qp-label qp-label-required" asp-for="Description">@L["Description"]</label>
                    <input class="qp-input" asp-for="Description" />
                    <span asp-validation-for="Description" class="qp-field-error"></span>
                </div>
            </form>
        </div>
    </div>
</div>
