# =============================================================================
# QueryPlus — local development environment template
# =============================================================================
#
# These values are DUMMY credentials for local Docker / laptop use only.
# Do NOT use them in production, staging, or any shared environment.
#
# Setup:
#   cp .env.example .env
#
# .env is gitignored and must never be committed.
# Docker Compose reads .env automatically for ${VAR} substitution.
# `dotnet run` loads .env from the repo root (if present) into the process.
# =============================================================================

# --- SQL Server (docker-compose sqlserver service) ---
MSSQL_SA_PASSWORD=Your_strong_Password123

# --- Keycloak admin (docker-compose keycloak service, dev mode only) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- ASP.NET Core (double-underscore = nested configuration) ---
# Host machine: SQL published on localhost:1433
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=QueryPlus;User Id=sa;Password=Your_strong_Password123;TrustServerCertificate=True;Encrypt=False

Keycloak__Authority=http://localhost:8080/realms/queryplus
Keycloak__ClientId=queryplus-web
# Must match docker/keycloak/realm-export.json client secret for local realm import.
Keycloak__ClientSecret=change-me-in-production
Keycloak__RequireHttpsMetadata=false

# Uncomment when the app runs inside Docker (Compose profile "full" / Dev Container):
# ConnectionStrings__DefaultConnection=Server=sqlserver,1433;Database=QueryPlus;User Id=sa;Password=Your_strong_Password123;TrustServerCertificate=True;Encrypt=False
# Keycloak__MetadataAddress=http://keycloak:8080/realms/queryplus/.well-known/openid-configuration
# Keycloak__BackchannelHost=keycloak
# Keycloak__BackchannelPort=8080
