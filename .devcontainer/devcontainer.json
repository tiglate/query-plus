{
  "name": "QueryPlus",
  "dockerComposeFile": ["../docker-compose.yml", "docker-compose.dev.yml"],
  "service": "app",
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-dotnettools.csdevkit",
        "ms-azuretools.vscode-docker",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "dotnet.defaultSolution": "QueryPlus.sln",
        "editor.formatOnSave": true
      }
    }
  },
  "forwardPorts": [5000, 1433, 8080],
  "portsAttributes": {
    "5000": { "label": "QueryPlus Web", "onAutoForward": "notify" },
    "1433": { "label": "SQL Server", "onAutoForward": "silent" },
    "8080": { "label": "Keycloak", "onAutoForward": "silent" }
  },
  "postCreateCommand": "dotnet restore && cd src/QueryPlus.Web && npm install || true",
  "remoteUser": "vscode"
}
